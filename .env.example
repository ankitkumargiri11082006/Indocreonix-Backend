PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/indocreonix
JWT_SECRET=replace_with_a_long_secure_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://indocreonix.vercel.app,https://indocreonix.com,https://www.indocreonix.com,https://your-frontend-domain.com,https://*.vercel.app
# Additional defaults are already allowed in code: https://*.vercel.app and https://*.netlify.app
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Email Provider (Resend only in this backend build) ───────────────────────
EMAIL_PROVIDER=resend

# Resend (works on Render Free because it uses HTTPS/443)
RESEND_API_KEY=your_resend_api_key
# Optional fallback from address
RESEND_FROM=info@indocreonix.com
RESEND_INFO_FROM=info@indocreonix.com
RESEND_CONTACT_FROM=contact@indocreonix.com
RESEND_CAREERS_FROM=careers@indocreonix.com
