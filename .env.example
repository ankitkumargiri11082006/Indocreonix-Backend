PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/indocreonix
JWT_SECRET=replace_with_a_long_secure_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://indocreonix.vercel.app,https://indocreonix.com,https://www.indocreonix.com,https://your-frontend-domain.com,https://*.vercel.app
# Additional defaults are already allowed in code: https://*.vercel.app and https://*.netlify.app
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Email / SMTP (Hostinger Mail Pro Lite) ────────────────────────────────────
# Hostinger SMTP settings — get these from hPanel → Email → Mail Pro → Connect Devices
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
# SMTP_USER = the primary mailbox you authenticate with (usually info@indocreonix.com)
SMTP_USER=info@indocreonix.com
SMTP_PASS=your_hostinger_mailbox_password
SMTP_REQUIRE_TLS=false
SMTP_IGNORE_TLS=false
SMTP_REJECT_UNAUTHORIZED=false
SMTP_CONNECTION_TIMEOUT=20000
SMTP_GREETING_TIMEOUT=15000
SMTP_SOCKET_TIMEOUT=30000
# Alias "From" addresses (create these as aliases in hPanel → Email → your mailbox → Aliases)
SMTP_INFO_FROM=info@indocreonix.com
SMTP_CONTACT_FROM=contact@indocreonix.com
SMTP_CAREERS_FROM=careers@indocreonix.com
